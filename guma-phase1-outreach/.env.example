# Resend
RESEND_API_KEY=re_...
FROM_EMAIL=Jake <jake@guma.ai>
REPLY_TO=jake@guma.ai

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://localhost:6379

# App
SITE_BASE_URL=https://guma.ai/sites
CLAIM_BASE_URL=https://guma.ai/claim

# Sending limits (warm-up schedule)
DAILY_SEND_LIMIT=200
BATCH_SIZE=50
SEND_DELAY_MS=3000
